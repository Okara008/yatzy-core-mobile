{
	"expo": {
		"scheme": "myApp",
		"name": "Yatzy Core",
		"slug": "yatzy-core",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/yatzy_icon.png",
		"userInterfaceStyle": "light",
		"newArchEnabled": true,
		"splash": {
		"image": "./assets/yatzy_icon.png",
		"resizeMode": "contain",
		"backgroundColor": "#ffffff"
		},
		"ios": {
			"supportsTablet": true
		},
		"android": {
		"package": "com.Okara008.yatzycore",
		"adaptiveIcon": {
			"foregroundImage": "./assets/yatzy_icon.png",
			"backgroundColor": "#ffffff"
		},
		"edgeToEdgeEnabled": true
		},
		"web": {
		"favicon": "./assets/yatzy_icon.png"
		},
		"plugins": [
			"expo-router"
		]
	}
}
