{
  "expo": {
    "scheme": "yatzyCore",
    "name": "Yatzy Core",
    "slug": "yatzy-core",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/yatzy_icon_splash.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/yatzy_icon_splash.png",
      "imageWidth": 400,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.Okara008.yatzycore",
      "adaptiveIcon": {
        "foregroundImage": "./assets/yatzy_icon_splash.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/yatzy_icon_splash.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c677e84a-c932-4667-8a58-8c7dd04f3168"
      }
    }
  }
}
